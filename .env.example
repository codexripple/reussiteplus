# Variables d'environnement — copier ce fichier en .env et remplir les valeurs

# Clé API Groq (gratuit sur https://console.groq.com/keys)
GROQ_API_KEY=gsk_votre_cle_ici

# Email transactionnel via Brevo (ex-Sendinblue) — 300 emails/jour gratuits
# Créer un compte sur https://app.brevo.com/ → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-votre_cle_brevo_ici

# Identité expéditeur (doit être un domaine vérifié dans Brevo)
MAIL_FROM=noreply@reussiteplus.cd
MAIL_FROM_NAME=RÉUSSITE+
